	number = {5},
	journal = {Cell},
	author = {Afshinnekoo, Ebrahim and Scott, Ryan T. and MacKay, Matthew J. and Pariset, Eloise and Cekanaviciute, Egle and Barker, Richard and Gilroy, Simon and Hassane, Duane and Smith, Scott M. and Zwart, Sara R. and Nelman-Gonzalez, Mayra and Crucian, Brian E. and Ponomarev, Sergey A. and Orlov, Oleg I. and Shiba, Dai and Muratani, Masafumi and Yamamoto, Masayuki and Richards, Stephanie E. and Vaishampayan, Parag A. and Meydan, Cem and Foox, Jonathan and Myrrhe, Jacqueline and Istasse, Eric and Singh, Nitin and Venkateswaran, Kasthuri and Keune, Jessica A. and Ray, Hami E. and Basner, Mathias and Miller, Jack and Vitaterna, Martha Hotz and Taylor, Deanne M. and Wallace, Douglas and Rubins, Kathleen and Bailey, Susan M. and Grabham, Peter and Costes, Sylvain V. and Mason, Christopher E. and Beheshti, Afshin},
